### load predefined .gitconfig
[include]
    path = ~/.proFILEs/linux/.gitconfig

### user specific setting
[user]
     name = av9300
    email = joongkeun.kim@lge.com

### ignore color prompt for repo init prompting
[color]
    ui = false

### path specific setting
# add path usign globbing after gitdir:
# add user .gitconfig in user.gitconfig.extra
[includeIf "gitdir:~/.proFILE*/"]
    path = ~/.proFILEs/user.gitconfig.proFILEs

