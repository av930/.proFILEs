#!/bin/bash
## ==========================================================================
##  revvserver - Gerrit server connection info manager
##  Standalone script: can be used independently from repp
##  Usage (terminal): revvserver [show|gen|en|edit|de|check|info|status|help] [server]
##                    (equivalent to: revv server <subcmd>)
##  Usage (source):   source revvserver  (functions available in shell)
##  Usage (via repp): revv server [cmd] [server]   (repp sources this file)
## ==========================================================================

## Find script directory for prelibrary
_REVVSERVER_SCRIPT=$(realpath "${BASH_SOURCE[0]:-$0}" 2>/dev/null || echo "${BASH_SOURCE[0]:-$0}")
_REVVSERVER_DIR="${_REVVSERVER_SCRIPT%/*}"

## Load prelibrary only if not already loaded (e.g. via repp → revvserver path)
## Guard: bbar() is defined by prelibrary; skip if already present
if ! declare -f bbar > /dev/null 2>&1; then
    if [ -e "${_REVVSERVER_DIR}/prelibrary" ]; then
        source "${_REVVSERVER_DIR}/prelibrary" > /dev/null
    elif [ -n "${proFILEdir}" ] && [ -e "${proFILEdir}/tools/prelibrary" ]; then
        source "${proFILEdir}/tools/prelibrary" > /dev/null
    else
        ## Minimal fallback color/logging functions if prelibrary is not found
        RED='\e[1;31m'; GREEN='\e[1;32m'; YELLOW='\e[1;33m'; cyan='\e[0;36m'; NCOL='\e[0m'
        err()  { printf "${RED}ERROR: ${NCOL}%s\n" "${*}" >&2 ;}
        warn() { printf "${YELLOW}WARN: ${NCOL}%s\n" "${*}" ;}
        clog() { printf "${cyan}%s ${NCOL}%s\n" "$1" "${*:2}" ;}
        info() { printf "${GREEN}INFO: ${NCOL}%s\n" "${*}" ;}
        bbar() { printf "${!1}%s ${NCOL}%b" "${2:+ $2}" "$3" ;}
        bar()  { printf "\n${cyan}[%s]${NCOL}\n" "${2:-}" ;}
    fi
fi

## REVV_SERVER is declared globally; safe to re-declare (idempotent for associative arrays)
declare -gA REVV_SERVER 2>/dev/null || declare -A REVV_SERVER



## revv ======================================================================================================================

function  revvserver_item() {
## ---------------------------------------------------------------------------
## return remote (gerrit server) info as a various type
## format: revvserver_item [29420|na|vgit|lamp|review]     [port|http|sub|domain|subdomain|path|url|remote|debug]
## exception: vgitxxx lampxxx will return only postfix after delimter _
##            aaa-bbb같이 -를 포함하는 sub은 -앞의 string(aaa)만 사용한다.

    local ret=0 remote=$1 prn _line remote_key tmp
    local return_type=$2

    ## 파라미터 개수가 반드시 2개이상이어야 동작
    [ "$remote" = "help" ] && return 0
    [ $# -lt 2 ] && { err "revvserver_item requires 2 params: <$remote> <$return_type>"; return 0; }

    ## server list로 부터 remote정보가 있는지 찾아 가져온다.
    _line=$(revvserver de "$remote")
    [ -z "$_line" ] && { err "server infomation[$remote] is null"; return 1; }

    local _item=$(echo "$_line"  | cut -d'|' -f2)

    case ${return_type} in                                                                         # return value
            http)    prn=$(echo "${_item%:*}")                                                     # http://vgit.lge.com/na
    ;;      port)    prn=$(echo "${_item##*:}")                                                    # 29420
    #;;       sub)   prn=$( echo "${_item#*://}"| awk -F[./:] '{sub(/-.*/,"",$1);print $1}'
    ;;       sub)    prn=$(echo "${_item#*://}"| awk -F[./:\ ] '{print $1}')                       # vgit
    ;;    domain)    prn=$(echo "${_item#*://}"| awk -F[./:\ ] '{print $2"."$3}')                  # lge.com
    ;; subdomain)    prn=$(echo "${_item#*://}"| awk -F[./:\ ] '{print $1"."$2"."$3}')             # vgit.lge.com
    ;;      path)    prn=$(echo "${_item#*://}"| awk -F[./:\ ] '{if ($4 !~ /^[0-9]+$/) print $4}') # na
    ;;       url)    prn=$(echo "${_item#*://}"| awk -F[./:\ ] '{$4="/"$4;gsub(/\/none_.*/,"",$4);print $1"."$2"."$3$4}')  # vgit.lge.com/na
    ;;       key)    prn=$(echo "$_line"  | cut -d'|' -f1)                                         # vgit_29420
    ;;      user)    prn=$(echo "$_line"  | cut -d'|' -f3)                                         # vc.integrator
    ;;      pass)    prn=$(echo "$_line"  | cut -d'|' -f4)                                         # N4lIA0SoQAoUfxlmCZudjNA12344
    ;;     alias)    prn=$(echo "$_line"  | cut -d'|' -f5)                                         # vgit_na,na
    ;;     debug)    prn=$(echo "${_item}")                                                        # http://vgit.lge.com/na:29420
    ;;         *)    prn='';  ret=1                                                                # error
    esac
    [ -n "$prn" ] && { echo "$prn" |xargs; return 0; }  || return 1
}



function revvserver_decode(){
## ---------------------------------------------------------------------------
## ~/.key_server.en에서 server정보가 들어있는 line을 리턴한다.
## 이름이 정확히 key에 match하면 해당 line을 리턴, 그렇지 않으면 alias에서 확인, 그렇지 않으면 url에서 확인
## $1: server name to search
## return: server info line (key|url|account|pass|alias)

    local server=$1
    local keyfile=$HOME/.key_server.en
    local setflag _line

    ## 파일 존재 확인
    if ! [ -f $keyfile ]; then
        err "You must create server connection info, use 'revv server gen'" >&2
        return 1
    fi

    ## REVV_SERVER 배열이 비어있으면 자동 로드
    if [ ${#REVV_SERVER[@]} -eq 0 ]; then
        local _data
        _data=$(cat "$keyfile" | openssl enc -base64 -d -aes-256-cbc -nosalt -pbkdf2 -pass pass:garbageKey | tail -n +2)
        ## 각 줄을 배열에 로드 (파이프로 구분된 필드 사용)
        while IFS='|' read -r key url account pass alias; do
            key=$(echo "$key" | xargs) # 앞뒤 공백 제거
            [ -z "$key" ] && continue  # 빈 줄 스킵
            REVV_SERVER["$key"]="${key}|${url}|${account}|${pass}|${alias}"
        done <<< "$_data"
    fi

    ## "load" 명령이면 여기서 종료 (배열만 로드)
    [ "$server" = "load" ] && return 0

    ## 1st try: 입력된 이름을 정리하여 key/alias/url 항목에서 찾기 from REVV_SERVER array (case-insensitive)
    ## suppress -x
    [[ $- == *x* ]] && { set +x ; setflag=true; }
    [[ $server =~ ^https?://[^/]+/[^/]+ ]] && server="${BASH_REMATCH[0]/https/http}"
    _line=$(printf "%s\n" "${REVV_SERVER[@]}" | sort | \
        awk -v tag="$server" -F '[[:space:]]*\\|' \
        'BEGIN{IGNORECASE=1} $1 == tag {print; exit}; $5 ~ tag {print; exit}; $2 ~ tag {print; exit}')

    ## 2nd try: manifest remote(REPPFILE_JSON_REMOTE 파일)에서 유추된 이름으로 찾기 (name -> review or fetch -> REMOTEKEY)
    if [ -z "$_line" ] && [ -f "${REPPFILE_JSON_REMOTE}" ] && [ "$server" != "origin" ]; then
        local _review _remotekey
        _review=$(jq -rM --arg jq_remote "$server" '.[]|select(.name == $jq_remote) | .review' "${REPPFILE_JSON_REMOTE}" 2>/dev/null)
        if [ -n "$_review" ] && [ "$_review" != "null" ]; then
            _line=$(printf "%s\n" "${REVV_SERVER[@]}" | sort | \
                awk -v tag="$_review" -F '[[:space:]]*\\|' \
                'BEGIN{IGNORECASE=1} $1 == tag {print; exit}; $5 ~ tag {print; exit}; $2 ~ tag {print; exit}')
        fi
        if [ -z "$_line" ]; then
            _remotekey=$(jq -rM --arg jq_remote "$server" '.[]|select(.name == $jq_remote) | .fetch' "${REPPFILE_JSON_REMOTE}" 2>/dev/null | cut -d'|' -f1)
            if [ -n "$_remotekey" ] && [ "$_remotekey" != "null" ]; then
                _line=$(printf "%s\n" "${REVV_SERVER[@]}" | sort | \
                    awk -v tag="$_remotekey" -F '[[:space:]]*\\|' \
                    'BEGIN{IGNORECASE=1} $1 == tag {print; exit}; $5 ~ tag {print; exit}; $2 ~ tag {print; exit}')
            fi
        fi
    fi

    ## 3rd try: 독립된 git으로 간주하여 git config명령결과 remote url에서 찾기 (subdomain_port -> REMOTEKEY like vgit_29420)
    if [ -z "$_line" ]; then
        local tmp guessed
        tmp=$(git config --get-regexp remote.$(git remote 2>/dev/null | head -1).url 2>/dev/null | cut -d' ' -f2 | head -1)
        if [ -n "$tmp" ]; then
            guessed=$(echo "${tmp#*://}" | awk -F[./:] '{print $1"_"$4}')
            if [ -n "$guessed" ]; then
                _line=$(printf "%s\n" "${REVV_SERVER[@]}" | sort | \
                    awk -v tag="$guessed" -F '[[:space:]]*\\|' \
                    'BEGIN{IGNORECASE=1} $1 == tag {print; exit}; $5 ~ tag {print; exit}; $2 ~ tag {print; exit}')
            fi
        fi
    fi

    ## 결과 출력
    if [ -z "$_line" ]; then
        warn "server infomation is not loaded or null"
        ${setflag:-false} && set -x
        return 1
    fi

    printf "%s\n" "$_line"
    ## suppress -x
    ${setflag:-false} && set -x
    return 0
}


function revvserver(){
## ---------------------------------------------------------------------------
# encoding as variable: code env <keyname> <key>
# encoding as file: code en <keyfile> <key>
# decode de <keyfile>
# $1 : cmd
# $2 : query server (vgit_na, na, as, lamp, ...)
local setflag
local cmd=$1 server=$2
local keyfile=$HOME/.key_server.en

    case $cmd in
       gen) #default server 접속정보 파일인 ~/.key_server를 생성한다.
            clog ".key_server" "is generated, \nplease add your server info with http key from: https://gerrit.url.com/settings/#HTTPCredentials\n"

            # REMOTEKEY must be made by 'SubDomain + Port'
            cat <<-EOF  >.key_server
			REMOTEKEY       |URL to GERRIT                                         |ACCOUNT         |HTTP KEY                      |ALIAS
			vgit_29420      |http://vgit.lge.com/na:29420                          |vc.integrator   |ex: N4lIA0SoQAoUfxlmCZudjNA1  |na,vgit_na
			vgit_29430      |http://vgit.lge.com/eu:29430                          |vc.integrator   |~~~                           |eu,vgit_eu
			vgit_29440      |http://vgit.lge.com/as:29440                          |vc.integrator   |~~~                           |as,vgit_as
			vgit_29550      |http://vgit.lge.com/adas:29550                        |vc.integrator   |                              |adas,vgit_adas
			vgit_29999      |http://vgit.lge.com/devops_test:29999                 |vc.integrator   |                              |devops,test,devops_test
			lamp_29418      |http://lamp.lge.com/review:29418                      |vc.integrator   |                              |review,lampauto,lamp
EOF
        cat .key_server

    ;;  en) #~/.key_server.en 로 암호화한다.
            if [ -f $HOME/.key_server ]; then
                clog "$HOME/.key_server will be converted to $keyfile with encrypting"
                cat $HOME/.key_server | openssl enc -base64 -e -aes-256-cbc -nosalt -pbkdf2  -pass pass:garbageKey > $keyfile
                rm -f $HOME/.key_server
            else
                clog "$keyfile" "could be updated by '$revv server editing' [$HOME/.key_server]"
                err "You must create server connection info, use '$revv server gen'"; return 1
            fi

    ;;edit) #~/.key_server.en으로 부터 ~/.key_server를 생성하여 편집할수 있게 해준다.
            cat $keyfile | openssl enc -base64 -d -aes-256-cbc -nosalt -pbkdf2 -pass pass:garbageKey >$HOME/.key_server
            clog "$HOME/.key_server" "is decrypted from $keyfile"
            [ -f "$HOME/.key_server" ] && cat $HOME/.key_server || { err "You must create server connection info, use '$revv server gen'"; return 1; }

    ;;  de) #~/.key_server.en에서 server정보가 들어있는 line을 리턴한다.
            revvserver_decode "$server"
            return $?


    ;;_verify) #.key_server.en의 무결성을 검증한다. (캐싱 기능 포함)
            local key url account invalid_count=0
            local verified_keyfile="${REPP_DIR:=$HOME}/log/.key_server_verified"

            # .repp/log 디렉토리 생성
            mkdir -p "${REPP_DIR}/log"

            # .key_server.en과 .key_server_verified 파일 비교 (캐싱)
            if [ -f "$verified_keyfile" ] && [ -f "$keyfile" ]; then
                if cmp -s "$keyfile" "$verified_keyfile"; then
                    return 0
                fi
            fi

            ## .key_server 무결성 검증: 모든 서버 항목의 필수 필드 확인
            [ ${#REVV_SERVER[@]} -eq 0 ] && { warn "No server information found in ~/.key_server.en\n\Generate file with: revv server gen"; return 1; }

            for server_key in "${!REVV_SERVER[@]}"; do
                url=$(revvserver_item "$server_key" http 2>/dev/null)
                account=$(revvserver_item "$server_key" user 2>/dev/null)
                key=$(revvserver_item "$server_key" pass 2>/dev/null)

                # 필수 필드 검증: key, url, account
                if [ -z "$server_key" ] || [ -z "$url" ] || [ -z "$account" ]; then
                    err "Server [$server_key] has missing required fields (key/url/account)"; return 1
                fi

                # HTTP key 길이 검증 (optional, 있으면 최소 길이 확인)
                if [ -n "$key" ] && (( ${#key} < 20 )); then
                    err "Server [$server_key] has invalid HTTP key (too short: ${#key} chars)"; return 1
                fi
            done

            # 검증 성공시 verified 파일에 복사
            cp "$keyfile" "$verified_keyfile" 2>/dev/null
            return 0

    ;;check|info) #revvserver_item 함수 test용으로 모든 format대로 제대로 출력하는지 확인할수 있다.
            test_revvserver_item $cmd

    ;;help) cat <<- EOF
			usage) revv server <cmd> <option>

			revv server   gen             #generate template .key_server file for easy creation
			revv server    en             #after update .key_server, encrypt it to .key_server.en
			revv server  edit             #encrypted .key_server.en will be decryped to .key_server to edit
			revv server    de vgit_na     #search vgit_na server and get info of it from .key_server.en
			revv server  show             #show current server info from .key_server.en
			revv server check             #check connection of server. if success, key is correct!
			revv server  info             #check connection of server and format of revvserver_item api
			revv server status            #check if server is active & gerrit connection is good
EOF
    ;;show|*)  #현재 .key_server파일을 보여준다.
            [ ! -f $keyfile ] && err "You must create server connection info, use '$revv server gen'"
            cat $keyfile | openssl enc -base64 -d -aes-256-cbc -nosalt -pbkdf2 -pass pass:garbageKey

            clog "You can refer:" "'revv server help'"

    esac
}



function test_revvserver_item() {
## ---------------------------------------------------------------------------
## check all format is well printed
## print remote (gerrit server) info for all supported format
## awk print 2nd line to last-1 line
#revvserver show |awk -F '|' 'NR>1{print $1}'
    local cmd=$1
    for _item in $(revvserver show |awk -F '|' 'NR>2 {print last} {last=$1}');do
        if [ "$cmd" = info ]||[ "$cmd" = check ]; then revvcheck_server $_item log; fi

        if [ "$cmd" = info ]; then
        for _test in http port sub domain subdomain path url key user pass alias debug;do
            bbar cyan "${_item##*/}:$_test"  "$(revvserver_item "${_item##*/}" "$_test")\n"
        done
        fi
    done
}



function revvcheck_server(){
## ---------------------------------------------------------------------------
# check gerrit is permitted for input user on git project > branch
# usage) revvcheck_server na log
# $1: target review system
# $2: log flag

    local server=$1
    local flag=$2
    local key=$(revvserver_item ${server}  pass)
    local user=$(revvserver_item ${server} user)

    if [ -z "${server}" ];
    then port=$(echo ${REPP_URL#*@} | grep -oP '(?<=:)[0-9]+(?=/)'); server=$(revvserver_item ${port} http)
    else port=$(revvserver_item ${server} port); server=$(revvserver_item ${server} http);
    fi
    #$DEBUG ["$server"]["$port"]

    ## gerrit api에 access가 가능한지를 gerrit version을 제대로 return하는지 여부로 판단한다.
    [ "${flag}" = "log" ] && bar inline "${server}"; echo "curl -su ${user}:${key} ${server}/a/config/server/version |sed '1d'| jq -cC '.'"
    REVV_VER=$(curl -su ${user}:${key} ${server}/a/config/server/version |sed '1d'| jq -cC '.')
    if ! [[ "${REVV_VER}" =~ [2-9].[0-9].[0-9]* ]]; then REVV_VER='NA'; err "gerrit is not working, please check"; return 1; fi

    if [ "${flag}" = "log" ]; then
        bar inline "step1.1-gerritserver: [remote] check if gerrit server is active (checked by $user)"
        clog try "check gerrit service is online from web"
        echo "ok. gerrit is working ${REVV_VER}"
    fi
    return 0
}



function revvcheck_account(){
## ---------------------------------------------------------------------------
# check gerrit is permitted for input user on git project > branch
# usage) revvcheck_account na joongkeun.kim log
# $1: target review system
# $2: target user
# $3: log flag


    local server=$1
    local user=$2
    local flag=$3
    local key=$(revvserver_item ${server} pass)
    local ret=()

    server=$(revvserver_item ${server} http)
    readarray -d',' -t ret < <(curl -su ${ACCOUNT}:${key} ${server}/a/accounts/?suggest\&q=${user}|sed '1d'| jq -c '.[]|{_account_id,username,name,email}'|sed  's/[{}"]//g')
    ! [[ "${ret[*]}" =~ "${user}" ]] && err "there is no account [${user}] in gerrit" && return 1

    ##get username & accountID from gerrit
    REVV_USERID="${ret[0]#*:}"
    REVV_USER="${ret[1]#*:}"

    if [ "${flag}" = "log" ]; then
        bar inline "step1.2-gerritserver: [remote] check if ${user} can access gerrit (checked by $ACCOUNT)"
        clog try "check current account is in gerrit system"
        echo "ok. gerrit account existed: ${ret[@]}"
        #declare -p ret
    fi
    return 0
}



function revvcheck_permission(){
## ---------------------------------------------------------------------------
# check gerrit is permitted for input user on git project > branch
# usage)  revvcheck_permission as joongkeun.kim honda/con/autosar tsu_26my_release create
# $1: target user
# $2: target review system
# $3: gitproject
# $4: branch
# $5: permission(https://gerrit-review.googlesource.com/Documentation/access-control.html#access_categories)
#     Abandon,Create(Create Reference),Delete(Delete Reference),Forge Author, Forge Committer,Forge Server,Owner,Push,Direct Push
#     Push Merge Commits,Create Annotated Tag,Read,Rebase,Revert,Submit,Submit (On Behalf Of),Edit Hashtags,Edit Topic Name
#

    local server=$1
    local user=$2
    local oriproject=$3 ;
    local gitproject=${oriproject//'/'/'%2F'}
    local branch=$4
    local perm=$5
    local key=$(revvserver_item ${server} pass)
    local log ret
    local file=$(mktemp)

    revvcheck_account ${server} ${user}

    #local port=$(echo ${REPP_URL#*@} | grep -oP '(?<=:)[0-9]+(?=/)')
    server=$(revvserver_item ${server} http);
    if [ -z "${oriproject}" ];then info "guide) repp connect help" && return 1;fi

    ##[ "${oriproject}" = "${REPP_PROJECT}" ] && server=origin #change remote name for manifest git to origin
    #curl -su vc.integrator:'F3ZYZofW1J~~~' http://vgit.lge.com/as/a/projects/honda%2Flinux%2Fbuild_tsu/check.access?account=7986\&ref=refs%2fheads%2fmaster\&perm=read
    bar inline "step1.3-gerritserver: [remote] check if ${user} can access git project (checked by $ACCOUNT)"
    clog try "check git name path is correct and can access"
    log=$(curl -su ${ACCOUNT}:${key} ${server}/a/projects/${gitproject}/check.access?account=${REVV_USERID})
    ret=$(echo "${log}" |sed '1d'| jq -c '.')
    ! [[ "${ret#*:}" =~ 200 ]] && err "check gerrit project error: ${log}" && return 1
    echo "ok. gerrit account[${REVV_USER}] can access by[read]: ${oriproject}"
    echo ${linemi}

    bar inline "step1.4-gerritserver: [remote] check if ${user} can access branch on the project (checked by $ACCOUNT)"
    clog try "check git/branch is correct and can access it [case sensitive]"
    dnlog "commit" "read,push,submit,abandon,pushMerge,revert,rebase,revert"
    dnlog "extra" "directPush,forgeCommitter,forgeAuthor,editTopicName,label-Code-Review"
    dnlog "branchtag" "create,delete,createTag,createSignedTag"
    dnlog "server" "priority,streamEvents,administrateServer"
    [ -z "${perm}" ] && perm="read"
    if [[ "${branch}" =~ "refs" ]]; then :
    elif [ -z "${branch}" ]; then branch="refs/heads/master";
    else branch="refs/heads/${branch}"
    fi
    branch="${branch//'/'/'%2F'}"

    #for branch in refs/heads/branch1 refs/heads/branch2; do 반복필요.
    log=$(set -x; curl -su ${ACCOUNT}:${key} ${server}/a/projects/${gitproject}/check.access?account=${REVV_USERID}\&ref=${branch}\&perm=${perm})
    if [ "$(echo "${log}" | head -1)" = "${JSON_IDFY}" ]; then log=$(echo "$log" | sed '1d'); else err "$log"; return 1; fi

    ##access하고자 하는 user의 group정보를 얻어와 어떤 group id가 아닌 group name으로 log를 출력해준다.
    curl -su ${ACCOUNT}:${key} ${server}/a/accounts/${user}/groups |sed '1d'|jq -crM '.[]|{id,name}'  > $file
    awk -F'"' '/id/ {id=$4} /name/ {name=$8; print "s#"id"#"name"#g"}' $file > /tmp/replace.sed
    echo ${log}| sed -f /tmp/replace.sed |sed "s/user ${REVV_USERID}/${REVV_USER}/g"| jq .
    ! [[ "$(echo "${log}" | jq -rM '.status')" = 200 ]] && { err "check gerrit project error"; return 1;}

    ##get username & accountID from gerrit
    echo "ok. gerrit branch[${branch}] existed and can accessed with[${perm}] permission by[${REVV_USER}]"

    return 0
}





function revvserverstatus(){
## ---------------------------------------------------------------------------
# find replication server
# $1 server-url
# $2 port-number
    local server_port=${REPP_URL#*@}
    local server=${1:-${server_port%:*}}
    local user=${2:-${USER}}
    local port=${3:-$(echo ${server_port} | grep -oP '(?<=:)[0-9]+(?=/)')}

    if [ -z "${server}" ] || [ -z "${port}" ] ; then info "usage) revv server status vgit.lge.com 29999"; return 0;fi
    ping $server -s 1016 -c 4 -A
    printf "${yellow}--------------------------------------------------------------------------------------\n${NCOL}"
    if [ $? -ne 0 ]; then continue; fi
    ssh ${user}@$server -p $port -o ConnectTimeout=2 -o ConnectionAttempts=1 gerrit show-caches
    if [ $? -ne 0 ]; then continue;fi
    printf "${yellow}--------------------------------------------------------------------------------------\n${NCOL}"
    echo "please check 1) ipg/ewma from ping, 2) AvgGet from gerrit connection"
}






## ==========================================================================
## Main entry point: when executed directly (not sourced), handle terminal commands
##
## Equivalent to "revv server <subcmd>" when repp is sourced.
## Usage (standalone terminal):
##   revvserver show              # same as: revv server show
##   revvserver gen               # same as: revv server gen
##   revvserver en                # same as: revv server en
##   revvserver edit              # same as: revv server edit
##   revvserver de <server>       # same as: revv server de <server>
##   revvserver check             # same as: revv server check
##   revvserver info              # same as: revv server info
##   revvserver status [srv] ...  # same as: revv server status ...
##   revvserver help              # same as: revv server help
## ==========================================================================
if ! (return 0 2>/dev/null); then
    # Running as a script (not sourced) — delegate to revvserver() function
    printf "${cyan}[TIP]${NCOL} To use 'revv server <subcmd>' syntax, source this file or repp:\n"
    printf "      ${YELLOW}source revvserver${NCOL}   # loads revvserver functions into current shell\n"
    printf "      ${YELLOW}source repp${NCOL}         # loads repp+revvserver, enables: revv server <subcmd>\n\n"
    case "${1:-show}" in
        status) revvserverstatus "${@:2}" ;;
             *) revvserver "${@}" ;;
    esac
fi
